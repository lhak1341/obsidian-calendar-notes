{
  "name": "obsidian-periodic-notes",
  "version": "0.0.17",
  "description": "Create/manage daily, weekly, and monthly notes",
  "author": "liamcain",
  "main": "main.js",
  "license": "MIT",
  "scripts": {
    "lint": "svelte-check && eslint . && tsc --noEmit",
    "lint:fix": "svelte-check && eslint . --fix",
    "dev": "bun esbuild.config.mjs",
    "build": "bun run lint && bun esbuild.config.mjs production",
    "deploy": "bun esbuild.config.mjs deploy",
    "release": "standard-version"
  },
  "standard-version": {
    "t": ""
  },
  "dependencies": {
    "@popperjs/core": "2.11.8",
    "lodash": "4.18.1",
    "obsidian": "1.13.1",
    "svelte": "5.56.4",
    "svelte-writable-derived": "3.1.1",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@tsconfig/svelte": "5.0.8",
    "@types/lodash": "4.17.24",
    "@types/moment": "2.13.0",
    "@types/node": "26.1.0",
    "@typescript-eslint/eslint-plugin": "8.62.1",
    "@typescript-eslint/parser": "8.62.1",
    "builtin-modules": "5.3.0",
    "dotenv": "17.4.2",
    "esbuild": "0.28.1",
    "esbuild-svelte": "0.9.5",
    "eslint": "10.6.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "moment": "2.30.1",
    "sass": "^1.50.0",
    "standard-version": "^9.3.2",
    "svelte-check": "4.7.1",
    "svelte-preprocess": "6.0.5",
    "typescript": "6.0.3"
  }
}
